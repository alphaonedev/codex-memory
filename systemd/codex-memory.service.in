[Unit]
Description=codex-memory localhost daemon
After=default.target

[Service]
Type=simple
ExecStart=@CODEX_MEMORYD@ --config @CONFIG_PATH@
Restart=on-failure
RestartSec=2
Environment=RUST_LOG=info

[Install]
WantedBy=default.target
